LOG_LEVEL=INFO
# Required to open the dashboard. Use a long, unique value.
DASHBOARD_PASSWORD=
AUTH_SESSION_TTL_MINUTES=480
# Keep this enabled when TLS is terminated in front of the dashboard.
AUTH_COOKIE_SECURE=true
DRY_RUN=true
POSTING_ENABLED=false
HEADLESS=true

# Use a long unique password. Values in DATABASE_URL must be URL-encoded.
POSTGRES_DB=x_autoposter
POSTGRES_USER=x_autoposter
POSTGRES_PASSWORD=
DATABASE_URL=
DOCKER_DATABASE_URL=

API_PORT=8000
API_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=80
# Leave empty when dashboard and API run in this Compose stack: Nginx proxies /api.
VITE_API_BASE_URL=
# Docker uses the same-origin /api proxy unless this is deliberately overridden.
# DOCKER_VITE_API_BASE_URL=

BACKEND_IMAGE=x-stealth-autoposter-backend:prod
FRONTEND_IMAGE=x-stealth-autoposter-frontend:prod
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5

X_BASE_URL=https://x.com
SLOW_MO_MS=0
VIEWPORT_WIDTH=1365
VIEWPORT_HEIGHT=768

AUTH_STATE_PATH=auth.json
DATA_PATH=data/tweets.txt
LOGS_DIR=logs
SCREENSHOTS_DIR=screenshots
TRACES_DIR=traces

AGENT_ENABLED=true
AGENT_QUEUE_PATH=data/queue.jsonl
AGENT_EVENTS_PATH=data/agent_events.jsonl
AGENT_PUBLISH_REQUIRES_APPROVAL=true
AGENT_REQUIRE_SUCCESSFUL_DRY_RUN_BEFORE_PUBLISH=true

MIN_ACTION_DELAY_MS=300
MAX_ACTION_DELAY_MS=1600
MIN_POST_INTERVAL_MINUTES=180
SCHEDULER_POLL_SECONDS=30
SCHEDULER_MAX_PUBLISH_ATTEMPTS=3
WARMUP_MIN_SCROLLS=2
WARMUP_MAX_SCROLLS=5
NAVIGATION_TIMEOUT_MS=60000
POST_TIMEOUT_MS=45000

# PROXY_URL=http://user:password@host:port
