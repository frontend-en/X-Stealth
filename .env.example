LOG_LEVEL=INFO
CORS_ORIGINS=
# Required to open the dashboard. Keep this value secret and do not expose it to Vite.
# DASHBOARD_PASSWORD=replace-with-a-long-unique-password
# AUTH_SESSION_TTL_MINUTES=480
# Set to true when the dashboard is served over HTTPS.
# AUTH_COOKIE_SECURE=true
DRY_RUN=true
POSTING_ENABLED=false
HEADLESS=true

# PostgreSQL for native backend commands. Docker services use DOCKER_DATABASE_URL.
POSTGRES_DB=x_autoposter
POSTGRES_USER=x_autoposter
POSTGRES_PASSWORD=x_autoposter_local
POSTGRES_PORT=55432
POSTGRES_BIND_ADDRESS=127.0.0.1
DATABASE_URL=postgresql://x_autoposter:x_autoposter_local@127.0.0.1:55432/x_autoposter
DOCKER_DATABASE_URL=postgresql://x_autoposter:x_autoposter_local@postgres:5432/x_autoposter

API_PORT=8000
API_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000
# Docker uses Nginx's same-origin /api proxy by default. Override only when
# deliberately hosting the API at another browser-accessible address.
# DOCKER_VITE_API_BASE_URL=

X_BASE_URL=https://x.com
SLOW_MO_MS=0
VIEWPORT_WIDTH=1365
VIEWPORT_HEIGHT=768

AUTH_STATE_PATH=auth.json
LOGS_DIR=logs
SCREENSHOTS_DIR=screenshots
TRACES_DIR=traces

AGENT_ENABLED=true
AGENT_PUBLISH_REQUIRES_APPROVAL=true
AGENT_REQUIRE_SUCCESSFUL_DRY_RUN_BEFORE_PUBLISH=true

# Required only for AI Studio. Keep these values on the backend; never expose them to Vite.
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Required for the daily Trend Radar's read-only X research. Keep this server-side.
X_BEARER_TOKEN=
TREND_RADAR_TIMEZONE=Europe/Moscow
TREND_RADAR_PROFILE=Русскоязычный рынок России и СНГ: новые легальные и этичные модели заработка с помощью ИИ для владельцев малого бизнеса и самостоятельных специалистов
TREND_RADAR_WINDOW_HOURS=24

MIN_ACTION_DELAY_MS=300
MAX_ACTION_DELAY_MS=1600
MIN_POST_INTERVAL_MINUTES=180
SCHEDULER_POLL_SECONDS=30
SCHEDULER_MAX_PUBLISH_ATTEMPTS=3
WARMUP_MIN_SCROLLS=2
WARMUP_MAX_SCROLLS=5
NAVIGATION_TIMEOUT_MS=60000
POST_TIMEOUT_MS=45000

# PROXY_URL=http://user:password@host:port
